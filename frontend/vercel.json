{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://decentralized-credential-verification-x6gz.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_DEMO_MODE": "true"
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install"
}
